[2.791833, "o", "\u001b[34m╭─\u001b[0m\u001b[34m──────────────────────────────────────\u001b[0m\u001b[34m \u001b[0m\u001b[1;34m1. Ollama Request\u001b[0m\u001b[34m \u001b[0m\u001b[34m───────────────────────────────────────\u001b[0m\u001b[34m─╮\u001b[0m\r\n\u001b[34m│\u001b[0m {                                                                                                \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m   \"model\": \"edge-mcp-caller:latest\",                                                             \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m   \"stream\": false,                                                                               \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m   \"options\": {                                                                                   \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m     \"temperature\": 0                                                                             \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m   },                                                                                             \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m   \"messages\": [                                                                                  \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m     {                                                                                            \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m       \"role\": \"user\",                                                                            \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m       \"content\": \"read the contents of config/settings.yaml\"                                     \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m     }                                                                                            \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m   ]                                                                                              \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m }                                                                                                \u001b[34m│\u001b[0m\r\n\u001b[34m╰─\u001b[0m\u001b[34m─────────────────────────────\u001b[0m\u001b[34m POST http://localhost:11434/api/chat \u001b[0m\u001b[34m─────────────────────────────\u001b[0m\u001b[34m─╯\u001b[0m\r\n"]
[2.792339, "o", "\u001b[34m╭─\u001b[0m\u001b[34m──────────────────────────────────────\u001b[0m\u001b[34m \u001b[0m\u001b[1;34m2. Model Response\u001b[0m\u001b[34m \u001b[0m\u001b[34m───────────────────────────────────────\u001b[0m\u001b[34m─╮\u001b[0m\r\n\u001b[34m│\u001b[0m \u001b[36mRaw:\u001b[0m    {\"tool\":\"read_file\",\"args\":{\"path\":\"config/settings.yaml\"}}                              \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m \u001b[36mTool:\u001b[0m   read_file                                                                                \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m \u001b[36mArgs:\u001b[0m   {\"path\": \"config/settings.yaml\"}                                                         \u001b[34m│\u001b[0m\r\n\u001b[34m╰──────────────────────────────────────────────────────────────────────────────────────────────────╯\u001b[0m\r\n"]
[2.793411, "o", "\u001b[3m                 Model Metrics                  \u001b[0m\r\n\u001b[2m┌───────────────┬──────────────────────────────┐\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mPrompt tokens\u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m18                          \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mOutput tokens\u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m18                          \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mLatency      \u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m331ms                       \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mSchema tokens\u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m0 (tools baked into weights)\u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m└───────────────┴──────────────────────────────┘\u001b[0m\r\n"]
[2.794133, "o", "\u001b[33m╭─\u001b[0m\u001b[33m────────────────────────────────────────\u001b[0m\u001b[33m \u001b[0m\u001b[1;33m3. MCP Request\u001b[0m\u001b[33m \u001b[0m\u001b[33m────────────────────────────────────────\u001b[0m\u001b[33m─╮\u001b[0m\r\n\u001b[33m│\u001b[0m {                                                                                                \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m   \"method\": \"tools/call\",                                                                        \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m   \"params\": {                                                                                    \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m     \"name\": \"read_file\",                                                                         \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m     \"arguments\": {                                                                               \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m       \"path\":                                                                                    \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m \"/home/adityonugrohoid/projects/edge-mcp-caller/tests/e2e/fixture/config/settings.yaml\"          \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m     }                                                                                            \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m   }                                                                                              \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m }                                                                                                \u001b[33m│\u001b[0m\r\n\u001b[33m╰─\u001b[0m\u001b[33m───────────────────────\u001b[0m\u001b[33m stdio -> @modelcontextprotocol/server-filesystem \u001b[0m\u001b[33m───────────────────────\u001b[0m\u001b[33m─╯\u001b[0m\r\n"]
[2.807219, "o", "\u001b[32m╭─\u001b[0m\u001b[32m───────────────────────────────────────\u001b[0m\u001b[32m \u001b[0m\u001b[1;32m4. MCP Response\u001b[0m\u001b[32m \u001b[0m\u001b[32m────────────────────────────────────────\u001b[0m\u001b[32m─╮\u001b[0m\r\n\u001b[32m│\u001b[0m app:                                                                                             \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   name: edge-mcp-test                                                                            \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   debug: true                                                                                    \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   port: 3000                                                                                     \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   log_level: info                                                                                \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m                                                                                                  \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m database:                                                                                        \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   driver: sqlite3                                                                                \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   host: localhost                                                                                \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   pool_size: 10                                                                                  \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m                                                                                                  \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m cache:                                                                                           \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   backend: local                                                                                 \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   ttl: 300                                                                                       \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m                                                                                                  \u001b[32m│\u001b[0m\r\n\u001b[32m╰──────────────────────────────────────────────────────────────────────────────────────────────────╯\u001b[0m\r\n"]
[2.808501, "o", "\u001b[3m                        MCP Metrics                        \u001b[0m\r\n\u001b[2m┌───────────────┬─────────────────────────────────────────┐\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mServer       \u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m@modelcontextprotocol/server-filesystem\u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mTool         \u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1mread_file                              \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mLatency      \u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m12ms                                   \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mResponse size\u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m171 chars                              \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m└───────────────┴─────────────────────────────────────────┘\u001b[0m\r\n"]
[2.809812, "o", "\u001b[3m                           End-to-End Summary                            \u001b[0m\r\n\u001b[35m┏━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━┓\u001b[0m\r\n\u001b[35m┃\u001b[0m\u001b[1m \u001b[0m\u001b[1mStage          \u001b[0m\u001b[1m \u001b[0m\u001b[35m┃\u001b[0m\u001b[1m \u001b[0m\u001b[1mDetail                                     \u001b[0m\u001b[1m \u001b[0m\u001b[35m┃\u001b[0m\u001b[1m \u001b[0m\u001b[1m Time\u001b[0m\u001b[1m \u001b[0m\u001b[35m┃\u001b[0m\r\n\u001b[35m┡━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━┩\u001b[0m\r\n\u001b[35m│\u001b[0m\u001b[36m \u001b[0m\u001b[36mModel inference\u001b[0m\u001b[36m \u001b[0m\u001b[35m│\u001b[0m 18 prompt -> 18 output tokens               \u001b[35m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m331ms\u001b[0m\u001b[1m \u001b[0m\u001b[35m│\u001b[0m\r\n\u001b[35m│\u001b[0m\u001b[36m \u001b[0m\u001b[36mMCP execution  \u001b[0m\u001b[36m \u001b[0m\u001b[35m│\u001b[0m read_file({\"path\": \"config/settings.yaml\"}) \u001b[35m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m 12ms\u001b[0m\u001b[1m \u001b[0m\u001b[35m│\u001b[0m\r\n\u001b[35m│\u001b[0m\u001b[1;35m \u001b[0m\u001b[1;35mTotal          \u001b[0m\u001b[1;35m \u001b[0m\u001b[35m│\u001b[0m\u001b[1;35m \u001b[0m\u001b[1;35m                                           \u001b[0m\u001b[1;35m \u001b[0m\u001b[35m│\u001b[0m\u001b[1;35m \u001b[0m\u001b[1;35m343ms\u001b[0m\u001b[1;35m \u001b[0m\u001b[35m│\u001b[0m\r\n\u001b[35m└─────────────────┴─────────────────────────────────────────────┴───────┘\u001b[0m\r\n"]
