[2.794446, "o", "\u001b[34m╭─\u001b[0m\u001b[34m──────────────────────────────────────\u001b[0m\u001b[34m \u001b[0m\u001b[1;34m1. Ollama Request\u001b[0m\u001b[34m \u001b[0m\u001b[34m───────────────────────────────────────\u001b[0m\u001b[34m─╮\u001b[0m\r\n\u001b[34m│\u001b[0m {                                                                                                \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m   \"model\": \"edge-mcp-caller:latest\",                                                             \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m   \"stream\": false,                                                                               \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m   \"options\": {                                                                                   \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m     \"temperature\": 0                                                                             \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m   },                                                                                             \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m   \"messages\": [                                                                                  \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m     {                                                                                            \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m       \"role\": \"user\",                                                                            \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m       \"content\": \"show the tree structure of the docs folder\"                                    \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m     }                                                                                            \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m   ]                                                                                              \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m }                                                                                                \u001b[34m│\u001b[0m\r\n\u001b[34m╰─\u001b[0m\u001b[34m─────────────────────────────\u001b[0m\u001b[34m POST http://localhost:11434/api/chat \u001b[0m\u001b[34m─────────────────────────────\u001b[0m\u001b[34m─╯\u001b[0m\r\n"]
[2.795014, "o", "\u001b[34m╭─\u001b[0m\u001b[34m──────────────────────────────────────\u001b[0m\u001b[34m \u001b[0m\u001b[1;34m2. Model Response\u001b[0m\u001b[34m \u001b[0m\u001b[34m───────────────────────────────────────\u001b[0m\u001b[34m─╮\u001b[0m\r\n\u001b[34m│\u001b[0m \u001b[36mRaw:\u001b[0m    {\"tool\":\"directory_tree\",\"args\":{\"path\":\"docs/\"}}                                        \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m \u001b[36mTool:\u001b[0m   directory_tree                                                                           \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m \u001b[36mArgs:\u001b[0m   {\"path\": \"docs/\"}                                                                        \u001b[34m│\u001b[0m\r\n\u001b[34m╰──────────────────────────────────────────────────────────────────────────────────────────────────╯\u001b[0m\r\n"]
[2.796197, "o", "\u001b[3m                 Model Metrics                  \u001b[0m\r\n\u001b[2m┌───────────────┬──────────────────────────────┐\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mPrompt tokens\u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m17                          \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mOutput tokens\u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m15                          \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mLatency      \u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m378ms                       \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mSchema tokens\u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m0 (tools baked into weights)\u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m└───────────────┴──────────────────────────────┘\u001b[0m\r\n"]
[2.796896, "o", "\u001b[33m╭─\u001b[0m\u001b[33m────────────────────────────────────────\u001b[0m\u001b[33m \u001b[0m\u001b[1;33m3. MCP Request\u001b[0m\u001b[33m \u001b[0m\u001b[33m────────────────────────────────────────\u001b[0m\u001b[33m─╮\u001b[0m\r\n\u001b[33m│\u001b[0m {                                                                                                \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m   \"method\": \"tools/call\",                                                                        \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m   \"params\": {                                                                                    \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m     \"name\": \"directory_tree\",                                                                    \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m     \"arguments\": {                                                                               \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m       \"path\": \"/home/adityonugrohoid/projects/edge-mcp-caller/tests/e2e/fixture/docs\"            \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m     }                                                                                            \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m   }                                                                                              \u001b[33m│\u001b[0m\r\n\u001b[33m│\u001b[0m }                                                                                                \u001b[33m│\u001b[0m\r\n\u001b[33m╰─\u001b[0m\u001b[33m───────────────────────\u001b[0m\u001b[33m stdio -> @modelcontextprotocol/server-filesystem \u001b[0m\u001b[33m───────────────────────\u001b[0m\u001b[33m─╯\u001b[0m\r\n"]
[2.807596, "o", "\u001b[32m╭─\u001b[0m\u001b[32m───────────────────────────────────────\u001b[0m\u001b[32m \u001b[0m\u001b[1;32m4. MCP Response\u001b[0m\u001b[32m \u001b[0m\u001b[32m────────────────────────────────────────\u001b[0m\u001b[32m─╮\u001b[0m\r\n\u001b[32m│\u001b[0m [                                                                                                \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   {                                                                                              \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m     \"name\": \"API.md\",                                                                            \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m     \"type\": \"file\"                                                                               \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   },                                                                                             \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   {                                                                                              \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m     \"name\": \"CHANGELOG.md\",                                                                      \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m     \"type\": \"file\"                                                                               \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   },                                                                                             \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   {                                                                                              \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m     \"name\": \"README.md\",                                                                         \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m     \"type\": \"file\"                                                                               \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   }                                                                                              \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m ]                                                                                                \u001b[32m│\u001b[0m\r\n\u001b[32m╰──────────────────────────────────────────────────────────────────────────────────────────────────╯\u001b[0m\r\n"]
[2.808635, "o", "\u001b[3m                        MCP Metrics                        \u001b[0m\r\n\u001b[2m┌───────────────┬─────────────────────────────────────────┐\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mServer       \u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m@modelcontextprotocol/server-filesystem\u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mTool         \u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1mdirectory_tree                         \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mLatency      \u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m10ms                                   \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mResponse size\u001b[0m\u001b[2m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m161 chars                              \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m└───────────────┴─────────────────────────────────────────┘\u001b[0m\r\n"]
[2.809792, "o", "\u001b[3m                      End-to-End Summary                       \u001b[0m\r\n\u001b[35m┏━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━┓\u001b[0m\r\n\u001b[35m┃\u001b[0m\u001b[1m \u001b[0m\u001b[1mStage          \u001b[0m\u001b[1m \u001b[0m\u001b[35m┃\u001b[0m\u001b[1m \u001b[0m\u001b[1mDetail                           \u001b[0m\u001b[1m \u001b[0m\u001b[35m┃\u001b[0m\u001b[1m \u001b[0m\u001b[1m Time\u001b[0m\u001b[1m \u001b[0m\u001b[35m┃\u001b[0m\r\n\u001b[35m┡━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━┩\u001b[0m\r\n\u001b[35m│\u001b[0m\u001b[36m \u001b[0m\u001b[36mModel inference\u001b[0m\u001b[36m \u001b[0m\u001b[35m│\u001b[0m 17 prompt -> 15 output tokens     \u001b[35m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m378ms\u001b[0m\u001b[1m \u001b[0m\u001b[35m│\u001b[0m\r\n\u001b[35m│\u001b[0m\u001b[36m \u001b[0m\u001b[36mMCP execution  \u001b[0m\u001b[36m \u001b[0m\u001b[35m│\u001b[0m directory_tree({\"path\": \"docs/\"}) \u001b[35m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m 10ms\u001b[0m\u001b[1m \u001b[0m\u001b[35m│\u001b[0m\r\n\u001b[35m│\u001b[0m\u001b[1;35m \u001b[0m\u001b[1;35mTotal          \u001b[0m\u001b[1;35m \u001b[0m\u001b[35m│\u001b[0m\u001b[1;35m \u001b[0m\u001b[1;35m                                 \u001b[0m\u001b[1;35m \u001b[0m\u001b[35m│\u001b[0m\u001b[1;35m \u001b[0m\u001b[1;35m387ms\u001b[0m\u001b[1;35m \u001b[0m\u001b[35m│\u001b[0m\r\n\u001b[35m└─────────────────┴───────────────────────────────────┴───────┘\u001b[0m\r\n"]
