[0.437065, "o", "\u001b[35m╭─\u001b[0m\u001b[35m──────────────────────────────────────────\u001b[0m\u001b[35m \u001b[0m\u001b[1;36mTool 4/14\u001b[0m\u001b[35m \u001b[0m\u001b[35m───────────────────────────────────────────\u001b[0m\u001b[35m─╮\u001b[0m\r\n\u001b[35m│\u001b[0m \u001b[1;35mEdge MCP Caller\u001b[0m\u001b[1m — directory_tree\u001b[0m                                                                 \u001b[35m│\u001b[0m\r\n\u001b[35m│\u001b[0m \u001b[2mServer: \u001b[0mfilesystem                                                                               \u001b[35m│\u001b[0m\r\n\u001b[35m│\u001b[0m \u001b[2mQuery:  \u001b[0m\"show the tree structure of the docs folder\"                                             \u001b[35m│\u001b[0m\r\n\u001b[35m╰──────────────────────────────────────────────────────────────────────────────────────────────────╯\u001b[0m\r\n"]
