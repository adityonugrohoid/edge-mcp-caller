# NVIDIA NIM API (for synthetic training data generation)
NVIDIA_API_KEY=your_nvidia_key_here

# Ollama Cloud API (alternative data generation backend)
OLLAMA_CLOUD_HOST=https://ollama.com
OLLAMA_API_KEY=your_ollama_key_here

# Anthropic API (optional — alternative data generation backend)
# ANTHROPIC_API_KEY=your_key_here

# HuggingFace (for model download)
HF_TOKEN=your_token_here

# Ollama Local (for inference)
OLLAMA_HOST=http://localhost:11434
